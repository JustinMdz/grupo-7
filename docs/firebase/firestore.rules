rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // COLECCIÓN: chat_messages
    // ============================================================================
    // Almacena todos los mensajes del chat (grupal y DM).
    // Estructura:
    // - id: string (ID único del mensaje)
    // - sender_id: string (user_id del remitente)
    // - sender_nickname: string (nickname del remitente)
    // - content: string (contenido del mensaje)
    // - type: "group" | "dm" (tipo de mensaje)
    // - recipient_id: string | null (solo en DM, user_id del destinatario)
    // - timestamp: string (ISO 8601)
    // - ttl: int | null (segundos hasta expirar)
    // - expires_at: string | null (ISO 8601, cuando expira)
    // - allow_read_receipt: bool (si notifica al remitente cuando leen)
    // - chat_key: string ("group" o "dm:uid_a:uid_b")
    
    match /chat_messages/{messageId} {
      // Lectura: Solo usuarios autenticados pueden leer
      allow read: if request.auth != null;
      
      // Escritura: El backend es el único que escribe (via Admin SDK)
      // Los clientes NO escriben directamente aquí (usan HTTP POST /api/chat/messages)
      allow write: if false;
      
      // Alternativa más permisiva si necesitas clientes escribiendo:
      // (no recomendado en producción)
      // allow create: if request.auth != null && 
      //   request.resource.data.sender_id == request.auth.uid;
      // allow update, delete: if false;
    }
    
    // ============================================================================
    // FALLBACK: NEGAR ACCESO A CUALQUIER OTRA COLECCIÓN
    // ============================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
